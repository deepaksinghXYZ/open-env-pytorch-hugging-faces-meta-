#The warehouse manager
import torch
import torch.nn as nn
import torchvision.models as models

class Agent(nn.Module):
    def _init__(self,num_bins=3):
        super(Agent,self).__init__()
        #Loading pre trained model for image recognition
        self.train=models.shufflenet_v2_x0_5(pretrained=True)
        #Replace last to match our sorting task
        num_ftrs=self.train.fc.in_features
        self.train.fc=nn.Linear(num_ftrs,num_bins)
    def forward(self,x):
        action_logistics=self.train(x)
        return action_logistics
model=Agent(num_bins=3)
input_image=torch.randn(1,3,224,224)
decision=model(input_image)
chosen_bin=torch.argmax(decision,dim=1)
print("Chosen bin for item",chosen_bin.item())


